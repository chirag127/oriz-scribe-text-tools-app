---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Fake data generator — Oriz Text Tools" description="Generate names, emails, addresses, UUIDs, sentences, and more. All locally with crypto.getRandomValues.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">fake data generator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Pick a generator, set a count, and get realistic-looking placeholder data. Randomness comes from <code>crypto.getRandomValues</code>; nothing is uploaded.</p>

    <div class="controls">
      <div class="ctl">
        <label class="pane-label mono" for="fk-type">type</label>
        <select id="fk-type" class="io single">
          <option value="name">full names</option>
          <option value="email">emails</option>
          <option value="uuid">UUID v4</option>
          <option value="phone">phone numbers</option>
          <option value="address">addresses</option>
          <option value="sentence">sentences</option>
          <option value="word">words</option>
          <option value="hex">hex colors</option>
          <option value="int">integers (0–9999)</option>
          <option value="date">dates (ISO)</option>
        </select>
      </div>
      <div class="ctl">
        <label class="pane-label mono" for="fk-count">count</label>
        <input id="fk-count" class="io single small" type="number" min="1" max="500" value="10" />
      </div>
      <button class="btn" id="fk-go">generate</button>
    </div>

    <div class="pane-label mono">output</div>
    <textarea id="fk-output" class="io" rows="14" readonly></textarea>
    <button class="copy-btn" id="fk-copy">copy</button>
    <p id="fk-error" class="err mono" hidden></p>
  </article>
</BaseLayout>

<script>
  const FIRST = ['Aarav','Ines','Mei','Jonas','Layla','Theo','Priya','Marcus','Yara','Hugo','Sana','Kenji','Nora','Ravi','Elena','Omar','Cleo','Felix','Anaya','Diego','Maya','Sven','Ada','Kai','Zara','Noah','Mira','Ezra','Anya'];
  const LAST = ['Patel','Okafor','Lindgren','Tanaka','Silva','Bergstrom','Kapoor','Costa','Ito','Nguyen','Hassan','Romero','Ferreira','Schneider','Singh','Reyes','Achterberg','Mehta','Muller','Kowalski','Vega','Park','Dubois','Adler','Iyer','Hoffman'];
  const STREETS = ['Maple','Oak','Cedar','Linden','Briar','Holloway','Garrick','Wexford','Ashbury','Marigold','Crestview','Larkspur'];
  const SUFFIX = ['St','Ave','Ln','Way','Rd','Blvd'];
  const CITIES = ['Aurora','Bridgeport','Calder','Dovecote','Ellsworth','Fairhaven','Glenhollow','Harpswell','Inverleith','Jasperton'];
  const WORDS = ['lorem','ipsum','dolor','sit','amet','consectetur','adipiscing','elit','sed','do','eiusmod','tempor','incididunt','ut','labore','et','dolore','magna','aliqua','quis','nostrud','exercitation','ullamco','laboris','nisi','aliquip','ex','ea','commodo','consequat','duis','aute','irure'];
  const DOMAINS = ['oriz.in','example.com','mail.co','inbox.dev','letters.io','penpal.net'];

  function rnd(n: number): number {
    const a = new Uint32Array(1);
    crypto.getRandomValues(a);
    return a[0] % n;
  }
  function pick<T>(arr: T[]): T { return arr[rnd(arr.length)]; }

  function uuid(): string {
    const b = new Uint8Array(16);
    crypto.getRandomValues(b);
    b[6] = (b[6] & 0x0f) | 0x40;
    b[8] = (b[8] & 0x3f) | 0x80;
    const h = Array.from(b, x => x.toString(16).padStart(2, '0')).join('');
    return `${h.slice(0,8)}-${h.slice(8,12)}-${h.slice(12,16)}-${h.slice(16,20)}-${h.slice(20)}`;
  }

  function fullName(): string { return `${pick(FIRST)} ${pick(LAST)}`; }
  function email(): string {
    const n = `${pick(FIRST)}.${pick(LAST)}`.toLowerCase().replace(/[^a-z.]/g, '');
    return `${n}${rnd(99)}@${pick(DOMAINS)}`;
  }
  function phone(): string {
    const a = (rnd(900) + 100).toString();
    const b = (rnd(900) + 100).toString();
    const c = (rnd(9000) + 1000).toString();
    return `+1 (${a}) ${b}-${c}`;
  }
  function address(): string {
    return `${rnd(9000) + 100} ${pick(STREETS)} ${pick(SUFFIX)}, ${pick(CITIES)}, ${String.fromCharCode(65 + rnd(26))}${String.fromCharCode(65 + rnd(26))} ${rnd(9000) + 1000}`;
  }
  function sentence(): string {
    const len = 6 + rnd(10);
    const w: string[] = [];
    for (let i = 0; i < len; i++) w.push(pick(WORDS));
    w[0] = w[0].charAt(0).toUpperCase() + w[0].slice(1);
    return w.join(' ') + '.';
  }
  function word(): string { return pick(WORDS); }
  function hex(): string {
    const b = new Uint8Array(3);
    crypto.getRandomValues(b);
    return '#' + Array.from(b, x => x.toString(16).padStart(2, '0')).join('');
  }
  function integer(): string { return String(rnd(10000)); }
  function isoDate(): string {
    const t = Date.now() - rnd(60 * 60 * 24 * 365 * 5) * 1000;
    return new Date(t).toISOString();
  }

  const gens: Record<string, () => string> = {
    name: fullName, email, uuid, phone, address, sentence, word, hex, int: integer, date: isoDate,
  };

  const type = document.getElementById('fk-type') as HTMLSelectElement;
  const countEl = document.getElementById('fk-count') as HTMLInputElement;
  const out = document.getElementById('fk-output') as HTMLTextAreaElement;
  const err = document.getElementById('fk-error') as HTMLElement;
  const go = document.getElementById('fk-go') as HTMLButtonElement;
  const copyBtn = document.getElementById('fk-copy') as HTMLButtonElement;

  function generate() {
    err.hidden = true;
    const n = Math.min(500, Math.max(1, parseInt(countEl.value, 10) || 1));
    countEl.value = String(n);
    const g = gens[type.value];
    if (!g) { err.hidden = false; err.textContent = 'unknown generator'; return; }
    const lines: string[] = [];
    for (let i = 0; i < n; i++) lines.push(g());
    out.value = lines.join('\n');
  }

  go.addEventListener('click', generate);
  type.addEventListener('change', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    copyBtn.textContent = 'copied!';
    setTimeout(() => { copyBtn.textContent = 'copy'; }, 1500);
  });
  generate();
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 1rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 60ch; margin: 0 0 2rem; }
  .lede code { background: var(--paper-2); padding: 0.05rem 0.3rem; }
  .controls { display: flex; flex-wrap: wrap; align-items: end; gap: 0.75rem; margin-bottom: 1rem; }
  .ctl { display: flex; flex-direction: column; }
  .pane-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin: 0 0 0.25rem; }
  .io { width: 100%; padding: 0.75rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; box-sizing: border-box; resize: vertical; }
  .io.single { padding: 0.5rem 0.75rem; width: auto; min-width: 180px; }
  .io.single.small { width: 100px; min-width: 0; }
  .btn { padding: 0.5rem 1rem; background: var(--accent); color: var(--paper); border: 1px solid var(--accent); font-family: var(--font-mono); font-size: 0.8125rem; cursor: pointer; }
  .btn:hover { filter: brightness(1.1); }
  .copy-btn { margin-top: 0.5rem; padding: 0.375rem 1rem; background: transparent; border: 1px solid var(--accent); color: var(--accent); font-family: var(--font-mono); font-size: 0.8125rem; cursor: pointer; }
  .copy-btn:hover { background: var(--accent); color: var(--paper); }
  .err { color: #c1440e; font-size: 12px; margin-top: 0.5rem; }
</style>
