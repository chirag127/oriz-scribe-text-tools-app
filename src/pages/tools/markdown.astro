---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Markdown Preview — Oriz Text Tools" description="Write Markdown and see a live rendered HTML preview side by side. All client-side.">
  <article class="tool wide">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">markdown preview</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="layout">
      <div class="input-pane">
        <label class="pane-label mono" for="md-input">markdown</label>
        <textarea id="md-input" class="io" rows="24" placeholder="# Hello&#10;&#10;Type **markdown** here…" spellcheck="false"></textarea>
      </div>
      <div class="output-pane">
        <div class="pane-label mono">preview</div>
        <div id="md-preview" class="md-preview"></div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  import { marked } from 'marked';

  const input = document.getElementById('md-input') as HTMLTextAreaElement;
  const preview = document.getElementById('md-preview') as HTMLElement;

  marked.setOptions({ gfm: true, breaks: true });

  async function render() {
    const html = await marked.parse(input.value);
    preview.innerHTML = html;
  }

  input.addEventListener('input', render);

  // Default content
  input.value = `# Markdown Preview

Welcome to the **Oriz** markdown previewer. Everything stays in your browser.

## Features

- Live rendering as you type
- **Bold**, *italic*, \`inline code\`
- [Links](https://oriz.in)
- Tables, blockquotes, and more

## Code block

\`\`\`js
const greet = name => \`Hello, \${name}!\`;
console.log(greet('World'));
\`\`\`

> A blockquote to test the renderer.

| Column A | Column B |
|----------|----------|
| cell 1   | cell 2   |
| cell 3   | cell 4   |
`;
  render();
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .tool.wide { max-width: none; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 700px) {
    .layout { grid-template-columns: 1fr 1fr; align-items: start; }
  }

  .pane-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem; }

  .io {
    width: 100%;
    padding: 1rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    resize: vertical;
    min-height: 400px;
  }

  .md-preview {
    padding: 1.25rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.7;
    min-height: 400px;
    overflow-y: auto;
  }
  .md-preview h1, .md-preview h2, .md-preview h3,
  .md-preview h4, .md-preview h5, .md-preview h6 {
    font-family: var(--font-display);
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .md-preview h1 { font-size: 1.75rem; }
  .md-preview h2 { font-size: 1.375rem; }
  .md-preview h3 { font-size: 1.125rem; }
  .md-preview p { margin: 0 0 0.875rem; }
  .md-preview code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--rule);
    padding: 0.1em 0.3em;
    border-radius: 2px;
  }
  .md-preview pre {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .md-preview pre code { background: none; padding: 0; }
  .md-preview blockquote {
    border-left: 3px solid var(--accent);
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    color: var(--muted);
  }
  .md-preview ul, .md-preview ol { padding-left: 1.5rem; margin: 0 0 0.875rem; }
  .md-preview li { margin-bottom: 0.25rem; }
  .md-preview table { border-collapse: collapse; width: 100%; margin: 1rem 0; font-size: 0.9rem; }
  .md-preview th, .md-preview td { border: 1px solid var(--rule); padding: 0.5rem 0.75rem; text-align: left; }
  .md-preview th { background: var(--paper-2); font-weight: 600; }
  .md-preview hr { border: none; border-top: 1px solid var(--rule); margin: 1.5rem 0; }
  .md-preview img { max-width: 100%; }
  .md-preview a { color: var(--accent); }
</style>
