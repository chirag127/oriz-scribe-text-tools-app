---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Word / Char / Sentence / Paragraph Counter — Oriz Text Tools" description="Count words, characters, sentences, and paragraphs live as you type. All client-side.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">word / char / sentence / paragraph counter</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="layout">
      <div class="input-pane">
        <label class="pane-label mono" for="counter-input">input</label>
        <textarea id="counter-input" class="io" placeholder="paste or type text here…" rows="16" spellcheck="false"></textarea>
      </div>
      <div class="output-pane">
        <div class="pane-label mono">stats</div>
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-num mono" id="stat-words">0</span>
            <span class="stat-label">words</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-chars">0</span>
            <span class="stat-label">characters</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-chars-no-space">0</span>
            <span class="stat-label">chars (no spaces)</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-sentences">0</span>
            <span class="stat-label">sentences</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-paragraphs">0</span>
            <span class="stat-label">paragraphs</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-lines">0</span>
            <span class="stat-label">lines</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-read-time">0 min</span>
            <span class="stat-label">read time</span>
          </div>
          <div class="stat-card">
            <span class="stat-num mono" id="stat-bytes">0</span>
            <span class="stat-label">bytes (UTF-8)</span>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const input = document.getElementById('counter-input') as HTMLTextAreaElement;

  function count(text: string) {
    const words = text.trim() === '' ? 0 : text.trim().split(/\s+/).length;
    const chars = text.length;
    const charsNoSpace = text.replace(/\s/g, '').length;
    const sentences = text.trim() === '' ? 0 : (text.match(/[^.!?]*[.!?]+/g) ?? []).length;
    const paragraphs = text.trim() === '' ? 0 : text.split(/\n\s*\n/).filter(p => p.trim() !== '').length;
    const lines = text === '' ? 0 : text.split('\n').length;
    const readTime = Math.max(1, Math.round(words / 200));
    const bytes = new TextEncoder().encode(text).length;

    (document.getElementById('stat-words') as HTMLElement).textContent = words.toLocaleString();
    (document.getElementById('stat-chars') as HTMLElement).textContent = chars.toLocaleString();
    (document.getElementById('stat-chars-no-space') as HTMLElement).textContent = charsNoSpace.toLocaleString();
    (document.getElementById('stat-sentences') as HTMLElement).textContent = sentences.toLocaleString();
    (document.getElementById('stat-paragraphs') as HTMLElement).textContent = paragraphs.toLocaleString();
    (document.getElementById('stat-lines') as HTMLElement).textContent = lines.toLocaleString();
    (document.getElementById('stat-read-time') as HTMLElement).textContent = `${readTime} min`;
    (document.getElementById('stat-bytes') as HTMLElement).textContent = bytes.toLocaleString();
  }

  input.addEventListener('input', () => count(input.value));
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 700px) {
    .layout { grid-template-columns: 1fr 1fr; align-items: start; }
  }

  .pane-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem; }

  .io {
    width: 100%;
    padding: 1rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    resize: vertical;
    min-height: 300px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .stat-card {
    background: var(--paper);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-num { font-size: 1.5rem; font-weight: 500; color: var(--accent); }
  .stat-label { font-size: 0.75rem; color: var(--muted); }
</style>
