---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Unicode Inspector — Oriz Text Tools" description="Paste text to see Unicode code points and character names. All client-side.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">unicode inspector</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="layout">
      <div class="input-pane">
        <label class="pane-label mono" for="uni-input">input</label>
        <textarea id="uni-input" class="io" rows="8" placeholder="paste text here… e.g. Hello 😀 こんにちは" spellcheck="false"></textarea>
        <div class="btn-row">
          <button class="btn" id="uni-inspect">inspect</button>
          <button class="btn" id="uni-clear">clear</button>
        </div>
      </div>
    </div>

    <div id="uni-output" class="uni-output" aria-live="polite">
      <span class="hint mono">click inspect to see code points</span>
    </div>
  </article>
</BaseLayout>

<script>
  // Unicode category abbreviations
  const CAT: Record<string, string> = {
    Lu: 'Uppercase Letter', Ll: 'Lowercase Letter', Lt: 'Titlecase Letter',
    Lm: 'Modifier Letter', Lo: 'Other Letter',
    Mn: 'Non-spacing Mark', Mc: 'Spacing Mark', Me: 'Enclosing Mark',
    Nd: 'Decimal Digit', Nl: 'Letter Number', No: 'Other Number',
    Pc: 'Connector Punctuation', Pd: 'Dash Punctuation', Ps: 'Open Punctuation',
    Pe: 'Close Punctuation', Pi: 'Initial Punctuation', Pf: 'Final Punctuation',
    Po: 'Other Punctuation',
    Sm: 'Math Symbol', Sc: 'Currency Symbol', Sk: 'Modifier Symbol', So: 'Other Symbol',
    Zs: 'Space Separator', Zl: 'Line Separator', Zp: 'Paragraph Separator',
    Cc: 'Control', Cf: 'Format', Cs: 'Surrogate', Co: 'Private Use', Cn: 'Unassigned',
  };

  function getCategory(cp: number): string {
    // Very rough category detection using unicode ranges
    if ((cp >= 0x0041 && cp <= 0x005A) || (cp >= 0xC0 && cp <= 0xD6)) return 'Lu';
    if ((cp >= 0x0061 && cp <= 0x007A) || (cp >= 0xE0 && cp <= 0xF6)) return 'Ll';
    if (cp >= 0x0030 && cp <= 0x0039) return 'Nd';
    if (cp === 0x0020 || cp === 0x00A0 || cp === 0x3000) return 'Zs';
    if (cp < 0x0020 || (cp >= 0x007F && cp <= 0x009F)) return 'Cc';
    if (cp >= 0x1F600 && cp <= 0x1FAFF) return 'So'; // Emoji
    if (cp >= 0x4E00 && cp <= 0x9FFF) return 'Lo'; // CJK
    if (cp >= 0x3040 && cp <= 0x30FF) return 'Lo'; // Hiragana/Katakana
    if (cp >= 0x0600 && cp <= 0x06FF) return 'Lo'; // Arabic
    if (cp >= 0x0900 && cp <= 0x097F) return 'Lo'; // Devanagari
    return 'Lo';
  }

  function cpHex(cp: number): string {
    return 'U+' + cp.toString(16).toUpperCase().padStart(4, '0');
  }

  function escape(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderChar(glyph: string, cp: number): string {
    const hex = cpHex(cp);
    const cat = getCategory(cp);
    const catLabel = CAT[cat] ?? cat;
    const isControl = cat === 'Cc';
    const display = isControl ? `<span class="ctrl">[ctrl]</span>` : `<span class="glyph">${escape(glyph)}</span>`;
    return `<div class="cp-card">
      ${display}
      <code class="cp-hex mono">${hex}</code>
      <span class="cp-dec mono">${cp}</span>
      <span class="cp-cat mono">${catLabel}</span>
    </div>`;
  }

  const inputEl = document.getElementById('uni-input') as HTMLTextAreaElement;
  const outputEl = document.getElementById('uni-output') as HTMLElement;

  function inspect() {
    const text = inputEl.value;
    if (!text) {
      outputEl.innerHTML = '<span class="hint mono">enter some text above then click inspect</span>';
      return;
    }
    const chars = [...text]; // spread splits on code points (handles surrogate pairs)
    const cards = chars.map(ch => {
      const cp = ch.codePointAt(0) ?? 0;
      return renderChar(ch, cp);
    });
    outputEl.innerHTML = `<p class="uni-meta mono">${chars.length} code point(s) · ${text.length} UTF-16 code unit(s)</p><div class="cp-grid">${cards.join('')}</div>`;
  }

  document.getElementById('uni-inspect')!.addEventListener('click', inspect);
  document.getElementById('uni-clear')!.addEventListener('click', () => {
    inputEl.value = '';
    outputEl.innerHTML = '<span class="hint mono">click inspect to see code points</span>';
  });
  inputEl.addEventListener('input', inspect);
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .pane-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.5rem; display: block; }

  .layout { margin-bottom: 1.5rem; }

  .io {
    width: 100%;
    padding: 1rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    resize: vertical;
    min-height: 140px;
  }

  .btn-row { display: flex; gap: 0.5rem; margin-top: 0.75rem; }
  .btn {
    padding: 0.375rem 1rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: background 100ms;
  }
  .btn:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }

  .hint { color: var(--muted); font-size: 0.875rem; }

  .uni-output {
    min-height: 60px;
  }

  .uni-meta { font-size: 11px; color: var(--muted); margin: 0 0 0.75rem; }

  .cp-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cp-card {
    display: grid;
    grid-template-rows: auto auto auto auto;
    align-items: center;
    gap: 0.1rem;
    padding: 0.625rem 0.75rem;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    min-width: 5rem;
    text-align: center;
  }

  .glyph {
    font-size: 1.5rem;
    line-height: 1.3;
    font-family: var(--font-display);
  }
  .ctrl { font-size: 0.7rem; color: var(--muted); font-family: var(--font-mono); }
  .cp-hex { font-size: 0.75rem; color: var(--accent); display: block; }
  .cp-dec { font-size: 0.7rem; color: var(--muted); display: block; }
  .cp-cat { font-size: 0.65rem; color: var(--muted); display: block; text-wrap: balance; }
</style>
