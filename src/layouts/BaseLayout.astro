---
import '~/styles/global.css'
import { pricingUrl } from '@chirag127/astro-shell/pricing-url'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz Text Tools — A scribe\'s drawer. Every keystroke stays local.', description = 'Case convert, counters, diff, markdown, LaTeX, ASCII art, faker, regex tester. All client-side.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://text.oriz.in').toString()
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">Text Tools</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href={pricingUrl('oriz-scribe-text-tools-app')}>pricing</a>
        <a href="https://account.oriz.in/sign-in?return=https://text.oriz.in/">sign in</a>
      </nav>
    </header>
    <div class="oriz-shell">
      <FamilySidebar slug="oriz-scribe-text-tools-app" title="Text Tools">
        <a slot="tools" href="/tools/case-convert/">Case converter</a>
        <a slot="tools" href="/tools/counter/">Counter</a>
        <a slot="tools" href="/tools/find-replace/">Find &amp; replace</a>
        <a slot="tools" href="/tools/text-diff/">Text diff</a>
        <a slot="tools" href="/tools/text-sorter/">Text sorter</a>
        <a slot="tools" href="/tools/lorem-ipsum/">Lorem ipsum</a>
        <a slot="tools" href="/tools/markdown/">Markdown preview</a>
        <a slot="tools" href="/tools/readability/">Readability</a>
        <a slot="tools" href="/tools/unicode-inspector/">Unicode inspector</a>
        <a slot="tools" href="/tools/regex/">Regex tester</a>
        <a slot="tools" href="/tools/ascii-art/">ASCII art</a>
        <a slot="tools" href="/tools/faker/">Fake data</a>
        <a slot="tools" href="/tools/latex/">LaTeX preview</a>
      </FamilySidebar>
      <main id="main" class="oriz-main"><slot /></main>
    </div>
    <footer class="site">
      <span>Oriz Text Tools · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>
